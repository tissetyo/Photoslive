{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["sin1"],
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    { "path": "/api/retention", "schedule": "17 3 * * *" }
  ],
  "rewrites": [
    { "source": "/setup", "destination": "/setup" },
    { "source": "/status", "destination": "/status" },
    { "source": "/superadmin", "destination": "/superadmin" },
    { "source": "/booth", "destination": "/booth" },
    { "source": "/:booth/admin", "destination": "/admin?booth=:booth" },
    { "source": "/:booth/sesi/:session", "destination": "/session?booth=:booth&session=:session" },
    { "source": "/:booth/:session", "destination": "/session?booth=:booth&session=:session" },
    { "source": "/:booth", "destination": "/booth?booth=:booth" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(), geolocation=()"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; img-src 'self' data: blob:; media-src 'self' blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        }
      ]
    }
  ]
}
